{
  "compilerOptions": {
    "target": "ES2022",

    "module": "Node16",
    "moduleResolution": "node16",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "baseUrl": ".",
    "paths": {
      "@auth/*": ["auth/*"],
      "@config/*": ["config/*"],
      "@data/*": ["data/*"],
      "@fixtures/*": ["fixtures/*"],
      "@helpers/*": ["tests/_support/*"],
      "@pages/*": ["pages/*"],
      "@resources/*": ["resources/*"],
      "@reporters/*": ["reporters/*"]
    },

    // Silence forward-looking TS 7.0 deprecation warnings (intentional)
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "**/*.ts"
  ]
}